# --- CROO / CAP (required to run the on-chain marketplace provider) ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_xxxxxxxxxxxxxxxxxxxxxxxx
GHOSTWRITER_SERVICE_ID=

# --- Base chain / attestation minting (optional; off-chain fallback if unset) ---
BASE_RPC_URL=https://mainnet.base.org
MINTER_PRIVATE_KEY=
ATTESTATION_CONTRACT=

# --- Plagiarism web search (optional; offline heuristic if unset) ---
SERPAPI_KEY=

# --- REST API + policy ---
PORT=8787
MIN_CONTENT_LENGTH=200
UNIQUE_THRESHOLD=80
